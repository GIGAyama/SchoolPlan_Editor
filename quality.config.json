{
  "entryHtml": "App.html",
  "requiredFiles": [
    "appsscript.json",
    "App.html",
    "App_Css.html"
  ],
  "ignoreDirectories": [
    ".git",
    ".clasp",
    "node_modules",
    "coverage",
    "dist"
  ],
  "manifest": {
    "forbiddenOauthScopes": [
      "https://www.googleapis.com/auth/drive",
      "https://mail.google.com/"
    ]
  },
  "securityExceptions": {
    "wildcardPostMessage": [
      "App.html",
      "docs/index.html"
    ],
    "xFrameAllowAll": [
      "07_WebApp.gs"
    ]
  },
  "maintainability": {
    "warningLineCount": 5000,
    "warningByteCount": 400000
  }
}
